# ─────────────────────────────────────────────────────────────
# AI LMS — Client Environment Variables
# Copy to ".env" to override defaults. All client vars must be
# prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Base URL for API calls. Leave empty to use the Vite dev proxy
# (recommended in development — see vite.config.js).
# For production, set this to your deployed backend, e.g.
#   VITE_API_URL=https://your-api.onrender.com/api
VITE_API_URL=
