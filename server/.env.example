# ─────────────────────────────────────────────────────────────
# AI LMS — Server Environment Variables
# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env file.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5500
NODE_ENV=development

# Frontend origin allowed by CORS (Vite dev server)
CLIENT_URL=http://localhost:4321

# MongoDB connection string (MongoDB Atlas or local)
# Example (Atlas): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai_lms?retryWrites=true&w=majority
# Example (local): mongodb://127.0.0.1:27017/ai_lms
MONGO_URI=mongodb://127.0.0.1:27017/ai_lms

# Auth secrets (used starting Phase 2). Use long random strings in production.
JWT_SECRET=change_me_access_token_secret
JWT_REFRESH_SECRET=change_me_refresh_token_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Seed admin account (created by `npm run seed`)
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@ailms.dev
ADMIN_PASSWORD=Admin@12345

# Cloudinary (Phase 3 — video/thumbnail upload). Leave blank to disable uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI / LLM (Phase 5 — quiz generation + grading). Using Groq (OpenAI-compatible).
# Get a free key at https://console.groq.com/keys
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Stripe (Phase 8 — payments). Use TEST keys. Webhook secret optional in dev.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# InsForge (optional — Google OAuth / BaaS). Leave blank to disable.
# 1) Sign up + create a project:  npx @insforge/cli login  &&  npx @insforge/cli link
# 2) Get keys with:               npx @insforge/cli metadata
# 3) Enable the Google provider in the InsForge dashboard (Auth Methods).
INSFORGE_BASE_URL=https://api.insforge.dev
INSFORGE_API_KEY=
INSFORGE_ANON_KEY=
# Datastore: 'mongo' (current/default) or 'insforge' (after the DB migration is done & tested).
DATA_BACKEND=mongo

# Email (Phase 9). Leave blank to auto-create an Ethereal test inbox in dev
# (preview links are logged to the server console).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=AI LMS <no-reply@ailms.dev>
